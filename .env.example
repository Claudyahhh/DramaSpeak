# Required for shared two-person rooms
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Recommended: generate a random secret of at least 32 bytes
ROOM_TOKEN_SECRET=
ROOM_TTL_SECONDS=86400
STORAGE_NAMESPACE=ai-drama

# Server-funded model access is disabled by default
ALLOW_SERVER_MODEL=false
TEXT_PROVIDER=glm
TEXT_API_KEY=
TEXT_MODEL=glm-5.2
TEXT_MAX_TOKENS=1200
TEXT_TEMPERATURE=0.7

IMAGE_PROVIDER=none
IMAGE_API_KEY=
IMAGE_MODEL=
